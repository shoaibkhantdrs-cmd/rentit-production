# ---------------------------------------------------------------------------
# Root env file — consumed by docker-compose.yml to configure all services.
# Copy to .env and adjust as needed: cp .env.example .env
# ---------------------------------------------------------------------------

# Postgres
POSTGRES_USER=rentit
POSTGRES_PASSWORD=rentit_dev_password
POSTGRES_DB=rentit
POSTGRES_PORT=5432

# Backend
BACKEND_PORT=4000
NODE_ENV=development
DATABASE_URL=postgresql://rentit:rentit_dev_password@postgres:5432/rentit
CORS_ORIGIN=http://localhost:5173
LOG_LEVEL=debug

# Backend auth (Phase 2) -- generate a real secret with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_a_64_byte_random_hex_secret
JWT_ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
JWT_ISSUER=rentit
JWT_AUDIENCE=rentit-clients
BCRYPT_SALT_ROUNDS=12
OTP_LENGTH=6
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_MESSAGING_WINDOW_MS=60000
RATE_LIMIT_MESSAGING_MAX=20

# Backend image upload / geocoding (Phase 3) -- see docs/phase-3.md
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
MAX_IMAGE_UPLOAD_BYTES=10485760
GOOGLE_MAPS_API_KEY=

# Backend chat/notifications/WhatsApp providers (Phase 5) -- see
# docs/phase-5.md "Provider setup guide". Every one of these is optional;
# leaving them blank keeps the app on its console-logging fallback.
FRONTEND_BASE_URL=http://localhost:5173
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=no-reply@rentit.example
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# Backend payments (Phase 6 Part 1) -- see docs/phase-6-payments.md
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
PAYMENT_CURRENCY=INR
FEATURED_LISTING_PRICE_AMOUNT=19900
FEATURED_LISTING_DURATION_DAYS=7
BOOST_LISTING_PRICE_AMOUNT=9900
BOOST_LISTING_DURATION_DAYS=3
RATE_LIMIT_WEBHOOK_WINDOW_MS=60000
RATE_LIMIT_WEBHOOK_MAX=120
RATE_LIMIT_PAYMENT_ORDER_WINDOW_MS=600000
RATE_LIMIT_PAYMENT_ORDER_MAX=10

# Backend observability (Phase 6 Part 4) -- see docs/phase-6-part4-observability.md
SENTRY_DSN=
SENTRY_RELEASE=
METRICS_TOKEN=

# Frontend
# VITE_STRIPE_PUBLISHABLE_KEY / VITE_RAZORPAY_KEY_ID are NOT needed here --
# the frontend fetches both public keys at runtime from GET /api/payments/config
# instead of duplicating them into a second env file that can drift out of sync.
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:4000
