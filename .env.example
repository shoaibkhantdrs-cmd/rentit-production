# ---------------------------------------------------------------------------
# Root env file — consumed by docker-compose.yml to configure all services.
# Copy to .env and adjust as needed: cp .env.example .env
# ---------------------------------------------------------------------------

# Postgres
POSTGRES_USER=rentit
POSTGRES_PASSWORD=rentit_dev_password
POSTGRES_DB=rentit
POSTGRES_PORT=5432

# Backend
BACKEND_PORT=4000
NODE_ENV=development
DATABASE_URL=postgresql://rentit:rentit_dev_password@postgres:5432/rentit
CORS_ORIGIN=http://localhost:5173
LOG_LEVEL=debug

# Backend auth (Phase 2) -- generate a real secret with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_a_64_byte_random_hex_secret
JWT_ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
JWT_ISSUER=rentit
JWT_AUDIENCE=rentit-clients
BCRYPT_SALT_ROUNDS=12
OTP_LENGTH=6
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=10

# Frontend
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:4000
