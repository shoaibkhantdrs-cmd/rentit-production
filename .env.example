# ---------------------------------------------------------------------------
# Root env file — consumed by docker-compose.yml to configure all services.
# Copy to .env and adjust as needed: cp .env.example .env
# ---------------------------------------------------------------------------

# Postgres
POSTGRES_USER=rentit
POSTGRES_PASSWORD=rentit_dev_password
POSTGRES_DB=rentit
POSTGRES_PORT=5432

# Backend
BACKEND_PORT=4000
NODE_ENV=development
DATABASE_URL=postgresql://rentit:rentit_dev_password@postgres:5432/rentit
CORS_ORIGIN=http://localhost:5173

# Frontend
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:4000
