# ---------------------------------------------------------------------------
# Production env file — consumed by docker-compose.prod.yml.
# Copy to .env.production and fill in REAL values. Never commit the real
# file (already covered by .gitignore's .env* rule). Unlike
# .env.example (dev), nothing here has a safe default baked into
# docker-compose.prod.yml -- every value below must be set explicitly, on
# purpose, so a misconfigured production deploy fails loudly at startup
# instead of silently running on a dev-only fallback secret.
# ---------------------------------------------------------------------------

# --- Postgres -----------------------------------------------------------------
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=rentit

# --- Backend core ---------------------------------------------------------
BACKEND_PORT=4000
# The real domain(s) the frontend is served from -- NOT localhost.
CORS_ORIGIN=https://app.example.com
LOG_LEVEL=info

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# env.ts throws at startup in production if this is unset -- there is no
# dev-only fallback in production, by design.
JWT_ACCESS_SECRET=
JWT_ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
JWT_ISSUER=rentit
JWT_AUDIENCE=rentit-clients
BCRYPT_SALT_ROUNDS=12
OTP_LENGTH=6
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_MESSAGING_WINDOW_MS=60000
RATE_LIMIT_MESSAGING_MAX=20

# --- Image upload / geocoding -- see docs/phase-6-part8-deployment-cloudinary.md, -google-maps.md
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
MAX_IMAGE_UPLOAD_BYTES=10485760
GOOGLE_MAPS_API_KEY=

# --- Email/SMS/push/WhatsApp -- see docs/phase-6-part8-deployment-smtp.md, -whatsapp.md
FRONTEND_BASE_URL=https://app.example.com
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=no-reply@example.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# --- Payments -- see docs/phase-6-payments.md "Provider setup"
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
PAYMENT_CURRENCY=INR
FEATURED_LISTING_PRICE_AMOUNT=19900
FEATURED_LISTING_DURATION_DAYS=7
BOOST_LISTING_PRICE_AMOUNT=9900
BOOST_LISTING_DURATION_DAYS=3
RATE_LIMIT_WEBHOOK_WINDOW_MS=60000
RATE_LIMIT_WEBHOOK_MAX=120
RATE_LIMIT_PAYMENT_ORDER_WINDOW_MS=600000
RATE_LIMIT_PAYMENT_ORDER_MAX=10

# --- Observability ----------------------------------------------------------
SENTRY_DSN=
SENTRY_RELEASE=
# Must be set in production -- GET /metrics is otherwise unauthenticated.
METRICS_TOKEN=
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=

# --- Frontend -----------------------------------------------------------------
FRONTEND_PORT=5173
# Baked into the static bundle at build time (see docker-compose.prod.yml's
# frontend build.args) -- the real public API URL, not localhost.
VITE_API_BASE_URL=https://api.example.com

# --- CI/CD (used by GitHub Actions, not by docker-compose.prod.yml itself) --
# See .github/workflows/build-and-push.yml and docs/phase-6-part6-cicd.md.
# BACKEND_IMAGE=ghcr.io/your-org/rentit-backend:latest
# FRONTEND_IMAGE=ghcr.io/your-org/rentit-frontend:latest
