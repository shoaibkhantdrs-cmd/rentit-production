NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://rentit:rentit_dev_password@localhost:5432/rentit
CORS_ORIGIN=http://localhost:5173
LOG_LEVEL=debug

# --- Auth / JWT -------------------------------------------------------------
# HS256 signing secret for access tokens. Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_a_64_byte_random_hex_secret
JWT_ACCESS_TOKEN_TTL_SECONDS=900
# Refresh tokens are opaque (not JWTs) but this TTL governs their lifetime.
REFRESH_TOKEN_TTL_SECONDS=2592000
JWT_ISSUER=rentit
JWT_AUDIENCE=rentit-clients

# --- Password hashing ---------------------------------------------------------
BCRYPT_SALT_ROUNDS=12

# --- OTP ----------------------------------------------------------------------
OTP_LENGTH=6
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5

# --- Rate limiting --------------------------------------------------------
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=10

# --- Cloudinary (image upload) ----------------------------------------------
# Dashboard -> Account Details. See docs/phase-3.md "Cloudinary setup".
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
MAX_IMAGE_UPLOAD_BYTES=10485760

# --- Google Maps (geocoding) -------------------------------------------------
# Google Cloud Console -> enable "Geocoding API" -> Credentials. See
# docs/phase-3.md "Google Maps setup".
GOOGLE_MAPS_API_KEY=
