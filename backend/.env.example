NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://rentit:rentit_dev_password@localhost:5432/rentit
# Comma-separated list -- the code defaults to both 5173 and 5174 even if
# this line is unset/removed, since Vite falls forward to 5174 whenever
# 5173 is already in use. Only needed here if you're serving the frontend
# from somewhere else entirely (a different port, a real domain, etc.).
CORS_ORIGIN=http://localhost:5173,http://localhost:5174
LOG_LEVEL=debug

# --- Auth / JWT -------------------------------------------------------------
# HS256 signing secret for access tokens. Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_a_64_byte_random_hex_secret
JWT_ACCESS_TOKEN_TTL_SECONDS=900
# Refresh tokens are opaque (not JWTs) but this TTL governs their lifetime.
REFRESH_TOKEN_TTL_SECONDS=2592000
JWT_ISSUER=rentit
JWT_AUDIENCE=rentit-clients

# --- Password hashing ---------------------------------------------------------
BCRYPT_SALT_ROUNDS=12

# --- OTP ----------------------------------------------------------------------
OTP_LENGTH=6
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5

# --- Rate limiting --------------------------------------------------------
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=10
# Chat messages + WhatsApp actions (contact-owner/inquiry/share) -- added
# during the production-readiness audit, see docs/phase-6-audit.md.
RATE_LIMIT_MESSAGING_WINDOW_MS=60000
RATE_LIMIT_MESSAGING_MAX=20

# --- Cloudinary (image upload) ----------------------------------------------
# Dashboard -> Account Details. See docs/phase-3.md "Cloudinary setup".
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
MAX_IMAGE_UPLOAD_BYTES=10485760

# --- Google Maps (geocoding) -------------------------------------------------
# Google Cloud Console -> enable "Geocoding API" -> Credentials. See
# docs/phase-3.md "Google Maps setup".
GOOGLE_MAPS_API_KEY=

# --- Chat / notifications / WhatsApp (Phase 5) -------------------------------
# Every provider below is optional -- container.ts falls back to a working
# console-logging implementation when its credentials are blank. See
# docs/phase-5.md "Provider setup guide" for how to obtain each one.
FRONTEND_BASE_URL=http://localhost:5173

# SMTP (email)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=no-reply@rentit.example

# Twilio (SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Firebase Cloud Messaging (push) -- paste the service-account private key
# as a single line with literal \n sequences; env.ts un-escapes them.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# WhatsApp Business Cloud API
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# --- Payments (Phase 6 Part 1) -----------------------------------------------
# Both gateways are wired in and selectable per-purchase from the frontend --
# fill in whichever one(s) you actually have accounts for. See
# docs/phase-6-payments.md "Provider setup" for exactly where each of these
# comes from in the Razorpay/Stripe dashboards.

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Dashboard -> Settings -> Webhooks -> (create one pointing at
# POST /api/webhooks/razorpay) -- the secret shown there, not your API secret.
RAZORPAY_WEBHOOK_SECRET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# Dashboard -> Developers -> Webhooks -> (create one pointing at
# POST /api/webhooks/stripe) -- the "Signing secret" shown there.
STRIPE_WEBHOOK_SECRET=

# Pricing (smallest currency unit -- paise for INR) and rate limiting for
# the two unauthenticated webhook endpoints.
PAYMENT_CURRENCY=INR
FEATURED_LISTING_PRICE_AMOUNT=19900
FEATURED_LISTING_DURATION_DAYS=7
BOOST_LISTING_PRICE_AMOUNT=9900
BOOST_LISTING_DURATION_DAYS=3
RATE_LIMIT_WEBHOOK_WINDOW_MS=60000
RATE_LIMIT_WEBHOOK_MAX=120
# Added during the Phase 6 Part 2 security audit -- order-creation
# endpoints call a paid external API per request.
RATE_LIMIT_PAYMENT_ORDER_WINDOW_MS=600000
RATE_LIMIT_PAYMENT_ORDER_MAX=10

# --- Observability (Phase 6 Part 4) ------------------------------------------
# Leave SENTRY_DSN blank to use the built-in NoOpErrorTracker (errors still
# go to the structured logger, just not to an external service) -- setting
# it is the only step required to enable real error reporting.
# Sentry -> Settings -> Projects -> (your project) -> Client Keys (DSN).
SENTRY_DSN=
SENTRY_RELEASE=

# Shared bearer token GET /metrics requires in its Authorization header.
# Leave blank in local dev; set a real random value in production and
# configure it as Prometheus's scrape_config `bearer_token`.
METRICS_TOKEN=
