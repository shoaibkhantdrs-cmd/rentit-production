# Root cause fix (Render deployment): Render's native Node build
# environment sets NODE_ENV=production by default for every web service,
# including during the *build* step, not just at runtime. npm's own
# `omit` config resolves to ["dev"] whenever NODE_ENV=production and
# nothing overrides it -- meaning `npm install`/`npm ci` silently skips
# every devDependency, even though this project's build step
# (`tsc -p tsconfig.json && tsc-alias -p tsconfig.json`) needs
# typescript, tsc-alias, and every @types/* package to run at all.
#
# That's the exact cause of Render's build failing with
# "Cannot find name 'process'", "Cannot find name 'setTimeout'", and
# "Could not find a declaration file for module 'express'" while the
# same install/build succeeds locally (NODE_ENV isn't forced to
# production during a local `npm install`) -- @types/node and
# @types/express are correctly declared in package.json, they were
# just never being installed on Render.
#
# This forces npm to always install devDependencies regardless of
# NODE_ENV, on every npm version Render might run. It does not change
# what ships in the final dist/ output or the runtime node_modules used
# by `node dist/server.js` -- it only affects `npm install`/`npm run build`.
production=false
