{
  "title": "RentIt Backend",
  "uid": "rentit-backend",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Request rate by route (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (method, route) (rate(rentit_http_requests_total[1m]))",
          "legendFormat": "{{method}} {{route}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Error rate (4xx + 5xx) by route",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum by (route, status_class) (rate(rentit_http_responses_by_status_total{status_class=~\"4xx|5xx\"}[5m]))",
          "legendFormat": "{{route}} {{status_class}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "p95 request duration (ms) by route",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, route) (rate(rentit_http_request_duration_ms_bucket[5m])))",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Process memory (bytes)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "rentit_process_memory_bytes",
          "legendFormat": "{{type}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Process uptime",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [{ "expr": "rentit_process_uptime_seconds" }]
    },
    {
      "id": 6,
      "title": "Total requests since start",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 16 },
      "targets": [{ "expr": "rentit_http_requests_in_flight_total" }]
    }
  ]
}
